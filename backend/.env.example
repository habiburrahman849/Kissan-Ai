# Copy to backend/.env and fill in values (never commit .env)

# Qwen / Alibaba DashScope
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# OpenWeatherMap
OPENWEATHER_API_KEY=

# Optional long-term memory
MEM0_API_KEY=

# JWT session secret (use a long random string in production / Render)
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168
ALLOW_GUEST_LOGIN=true
AUTH_DEV_BYPASS=true

# development | production
ENVIRONMENT=development

# SQLite path (relative to backend/ when using sqlite:///./...)
DATABASE_URL=sqlite:///./kissan_ai_v2.db

# Frontend static files relative to backend/ (repo root HTML/CSS/JS)
FRONTEND_DIR=..
